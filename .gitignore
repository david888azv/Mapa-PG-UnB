# Cache do pipeline batch — só serve para regerar JSONs offline (~9 GB)
build/cache/

# Subprojeto pip/ — caches e saídas são 100% regeneráveis pelos scripts
pip/cache_unb/
pip/cache_nac/
pip/saida/

# Pastas de pesquisa PIP-2 — NÃO PUBLICAR. Contêm o CSV bruto do CiteScore
# (Scopus/Elsevier), cuja redistribuição é vedada pelos termos da API gratuita.
# Só resultados agregados vão para docs/. Blindagem contra `git add` acidental.
pip-2-refatorado/
pip-2-refatorado-citescore/
pip-2-refatorado-hibrido/
pip-2-comparativo-edicoes/
**/dados_citescore/
**/scopus_citescore_2025/

# Backups gerados (ex.: correção do registry)
*.bak

# Logs do pipeline e arquivos temporários
*.log
*.pyc
__pycache__/

# Editores
.vscode/
.idea/
*.swp
.DS_Store
docs/SUMMARY.txt

# Backups do patch_fisica_meta.py. A regra `*.bak` acima NÃO os pega: o nome é
# `area-astronomia-fisica.json.bak-<timestamp>`, com sufixo depois do .bak.
docs/dados/*.bak-*

# Recorte de pesquisa por programa (PPGDIP/UFRJ) — mesma política das pastas pip*:
# análise interna, não faz parte do app publicado. Lê o estratos_por_programa.json do
# PIP-2, que é derivado do CSV bruto do CiteScore (redistribuição vedada).
ppgdip-medicina-ufrj/

# Backups do dataset publicado, gerados antes de rebuilds grandes (dezenas de MB).
# Reversao tambem esta no historico do git; a pasta e conveniencia local.
_backup_*/
